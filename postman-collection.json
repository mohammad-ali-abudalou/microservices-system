{
  "info": {
    "_postman_id": "microservices-oauth2-collection",
    "name": "Microservices OAuth2 Collection",
    "description": "OAuth2 and API testing collection for microservices with Keycloak integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "accessToken",
        "value": "",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      },
      {
        "key": "tokenType",
        "value": "Bearer",
        "type": "string"
      },
      {
        "key": "grant_type",
        "value": "authorization_code",
        "type": "string"
      },
      {
        "key": "accessTokenUrl",
        "value": "{{keycloak_url}}/realms/master/protocol/openid-connect/token",
        "type": "string"
      },
      {
        "key": "authUrl",
        "value": "{{keycloak_url}}/realms/master/protocol/openid-connect/auth",
        "type": "string"
      },
      {
        "key": "redirect_uri",
        "value": "http://localhost:3000/callback",
        "type": "string"
      },
      {
        "key": "clientId",
        "value": "{{client_id}}",
        "type": "string"
      },
      {
        "key": "clientSecret",
        "value": "{{client_secret}}",
        "type": "string"
      },
      {
        "key": "scope",
        "value": "openid profile email",
        "type": "string"
      },
      {
        "key": "state",
        "value": "random",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Access Token (Client Credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access_token);",
                  "    console.log('Access Token saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                },
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "openid profile email",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/master/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "master",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          }
        },
        {
          "name": "Get Token (Password Flow)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access_token);",
                  "    pm.environment.set('refresh_token', jsonData.refresh_token);",
                  "    console.log('Tokens saved to environment');",
                  "    console.log('Token expires in: ' + jsonData.expires_in + ' seconds');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                },
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "openid profile email",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/master/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "master",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/master/protocol/openid-connect/token/introspect",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "master",
                "protocol",
                "openid-connect",
                "token",
                "introspect"
              ]
            }
          }
        },
        {
          "name": "Decode Token (view JWT claims)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://jwt.io/#id_token={{access_token}}",
              "protocol": "https",
              "host": [
                "jwt.io"
              ],
              "hash": "id_token={{access_token}}"
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_gateway_url}}/api/order/all",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "api",
                "order",
                "all"
              ]
            }
          }
        },
        {
          "name": "Place Order",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"orderNumber\":\"ORD-001\",\"userId\":\"user123\",\"totalPrice\":99.99,\"orderLineItemsList\":[{\"skuCode\":\"ITEM-001\",\"price\":99.99,\"quantity\":1}]}"
            },
            "url": {
              "raw": "{{api_gateway_url}}/api/order/place-order",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "api",
                "order",
                "place-order"
              ]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_gateway_url}}/api/order/{{order_id}}",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "api",
                "order",
                "{{order_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Get All Inventory",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_gateway_url}}/api/inventory/all",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "api",
                "inventory",
                "all"
              ]
            }
          }
        },
        {
          "name": "Check Stock",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{api_gateway_url}}/api/inventory/{{sku_code}}",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{sku_code}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Gateway Health",
      "item": [
        {
          "name": "Gateway Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_gateway_url}}/actuator/health",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Gateway Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_gateway_url}}/actuator/prometheus",
              "host": [
                "{{api_gateway_url}}"
              ],
              "path": [
                "actuator",
                "prometheus"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "keycloak_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "api_gateway_url",
      "value": "http://localhost:9000",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "postman-client",
      "type": "string"
    },
    {
      "key": "client_secret",
      "value": "YOUR_CLIENT_SECRET_HERE",
      "type": "string"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "password",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "sku_code",
      "value": "ITEM-001",
      "type": "string"
    }
  ]
}

